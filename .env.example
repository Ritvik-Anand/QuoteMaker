# Copy this to .env and fill in your values (for local development only)

# Required: DeepSeek API key for PDF catalog parsing
DEEPSEEK_API_KEY=sk-your-key-here

# Required in production: long random string for session security
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# PostgreSQL connection string (set this on Vercel)
# Leave blank for local development — SQLite is used automatically
# DATABASE_URL=postgresql://user:password@host/dbname

# Local SQLite path (optional, only used when DATABASE_URL is not set)
# DATABASE_PATH=./quotation_maker.db

# First admin account (created automatically on first run)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=choose-a-strong-password
