# Copy this to .env and fill in your values (for local development only)

# Required: DeepSeek API key for PDF catalog parsing
# Get one at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here

# Required in production: long random string for session security
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Optional: path to the SQLite database file
# Default: quotation_maker.db in the project folder
# On Railway, point this to your persistent volume, e.g. /data/quotation_maker.db
# DATABASE_PATH=/data/quotation_maker.db

# Optional: credentials for the first admin account (created on first run)
# If not set, username defaults to "admin" and a random password is printed to the console
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=choose-a-strong-password
